{
  "id": "job",
  "label": "Job",
  "format": "custom",
  "repeatable": true,
  "status": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "StructuredText",
        "config": {
          "label": "Titre",
          "placeholder": "Titre de l'offre",
          "single": "heading1"
        }
      },
      "publication_date": {
        "type": "Date",
        "config": {
          "label": "Date de publication"
        }
      },
      "short_desc": {
        "type": "Text",
        "config": {
          "label": "Description courte",
          "placeholder": "Description affichée sur la carte"
        }
      },
      "long_desc": {
        "type": "StructuredText",
        "config": {
          "label": "Description longue",
          "placeholder": "Description complète de l'offre",
          "allowTargetBlank": true,
          "multi": "paragraph,heading2,heading3,strong,em,list-item,o-list-item,hyperlink"
        }
      },
      "tags": {
        "type": "Group",
        "config": {
          "label": "Tags",
          "fields": {
            "tag": {
              "type": "Text",
              "config": {
                "label": "Tag",
                "placeholder": "ex: React, Next.js, TypeScript"
              }
            }
          }
        }
      },
      "admin_emails": {
        "type": "Group",
        "config": {
          "label": "Emails administrateurs",
          "fields": {
            "email": {
              "type": "Text",
              "config": {
                "label": "Email",
                "placeholder": "admin@example.com"
              }
            }
          }
        }
      },
      "expiration_date": {
        "type": "Date",
        "config": {
          "label": "Date d'expiration"
        }
      }
    }
  }
}
